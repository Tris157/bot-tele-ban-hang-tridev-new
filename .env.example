# Telegram
BOT_TOKEN=123456:ABCDEF_your_bot_token
ADMIN_IDS=123456789,987654321

# SePay / VietQR
# Ví dụ ngân hàng: MBBank, Vietcombank, VietinBank, ACB, BIDV, Techcombank...
SEPAY_BANK_CODE=MBBank
SEPAY_ACCOUNT_NO=1234567890
SEPAY_ACCOUNT_NAME=NGUYEN VAN A
SEPAY_QR_TEMPLATE=compact

# Xác thực webhook SePay
# api_key: SePay gửi header Authorization: Apikey <key>
# secret_key: SePay gửi header X-Secret-Key: <secret>
# none: chỉ dùng test local, không dùng production
SEPAY_AUTH_MODE=api_key
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
SEPAY_WEBHOOK_SECRET_KEY=your_sepay_secret_key_if_using_secret_key_mode

# Domain public để SePay gọi webhook. Local thì dùng ngrok/cloudflared.
PUBLIC_BASE_URL=https://your-domain.com

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Database
DATABASE_PATH=shop.db
